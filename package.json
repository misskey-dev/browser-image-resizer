{
  "name": "@misskey-dev/browser-image-resizer",
  "version": "2024.1.0",
  "description": "A browser-based utility to downscale and resize images using OffscreenCanvas",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./algorithms/*": {
      "types": "./dist/algorithms/*.d.ts",
      "import": "./dist/algorithms/*.js"
    }
  },
  "author": "Eric Nograles <grales@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "cd tests/vite-project && pnpm run dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/misskey-dev/browser-image-resizer.git"
  }
}
